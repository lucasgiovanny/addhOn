  "options": {
    "step": {
      "init": {
        "title": "Opções de depuração",
        "data": {
          "enable_debug": "Ativar registo de depuração",
          "enable_mqtt_debug": "Ativar depuração MQTT em tempo real"
        },
        "data_description": {
          "enable_debug": "Eleva o nível de registo desta integração para DEBUG (início de sessão, descoberta de dispositivos, polling, comandos). Desative para voltar ao nível configurado no Home Assistant. O ruído do MQTT em tempo real continua suprimido, a menos que o respetivo botão esteja ativado.",
          "enable_mqtt_debug": "Torna o canal MQTT em tempo real muito verboso. Normalmente mantenha desativado; cobre apenas o logger MQTT desta integração, não as bibliotecas AWS IoT subjacentes (para essas, use a configuração de logger do Home Assistant)."
        }
      }
    }
  },
  "services": {
    "refresh": {
      "name": "Atualizar agora",
      "description": "Força uma consulta imediata à nuvem para todas as contas hOn configuradas. O equivalente chamável por automações do botão \"Atualizar agora\" de cada dispositivo: pede a todos os coordenadores carregados que procurem dados novos imediatamente, em vez de aguardar a próxima consulta agendada. Não recebe opções e aplica-se à integração inteira."
    },
    "set_log_level": {
      "name": "Definir nível de registo de diagnóstico",
      "description": "Altera o nível de registo da integração Haier hOn e dos loggers do cliente hOn nativo usados para diagnosticar o início de sessão, a descoberta de dispositivos, a reautenticação e o polling. Use \"debug\" quando dispositivos não aparecerem e depois volte para \"warning\" para reduzir o ruído. Não ativa o ruído do MQTT em tempo real: para isso use o serviço dedicado set_mqtt_log_level.",
      "fields": {
        "level": {
          "name": "Nível",
          "description": "Nível de registo de diagnóstico a aplicar."
        }
      }
    },
    "set_mqtt_log_level": {
      "name": "Definir nível de registo do MQTT",
      "description": "Altera o nível de registo do canal MQTT em tempo real do hOn. Por predefinição, o ruído de tentativas de religação é silenciado (warning). Use \"debug\" para diagnosticar problemas de push em tempo real e depois \"warning\" para silenciar de novo. Não é persistente: volta a silenciado após reiniciar o Home Assistant.",
      "fields": {
        "level": {
          "name": "Nível",
          "description": "Nível de registo a aplicar ao canal MQTT em tempo real do hOn."
        }
      }
    }
  },
